# По умолчанию совпадает с docker-compose.yml в корне репозитория: docker compose up -d
DATABASE_URL=postgresql://ventmash:ventpass@127.0.0.1:5432/ventmash
# Свой PostgreSQL: postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@127.0.0.1:5432/ventmash (спецсимволы в пароле — URL-кодирование)
# Либо пользователь в URL + отдельно: DATABASE_PASSWORD=… (см. config.py)
# Локально без пароля по TCP — только при особой настройке pg_hba:
# DATABASE_URL=postgresql://localhost/ventmash
# Опционально: размер пула (см. database.py)
# DB_POOL_MIN=1
# DB_POOL_MAX=10
PORT=8000
# Путь к CSV каталога (по умолчанию ../data/ventsearch_massive_sorted.csv относительно backend/)
# CSV_PATH=/absolute/path/to/ventsearch_massive_sorted.csv
# При запросах к каталогу API сравнивает файл с БД (mtime+размер; при расхождении — SHA-256 и при необходимости переимпорт).
# Origins статического фронтенда (через запятую)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
